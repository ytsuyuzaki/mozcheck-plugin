{
	"name": "mozcheck",
	"version": "0.1.0",
	"private": true,
	"description": "WordPress plugin development scaffold",
	"author": "ytsuyuzaki",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"plugin"
	],
	"homepage": "https://github.com/ytsuyuzaki/mozcheck-plugin",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ytsuyuzaki/mozcheck-plugin.git"
	},
	"bugs": {
		"url": "https://github.com/ytsuyuzaki/mozcheck-plugin/issues"
	},
	"files": [
		"mozcheck.php",
		"assets",
		"includes",
		"languages",
		"uninstall.php",
		"readme.txt"
	],
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@wordpress/env": "^11.7.0",
		"@wordpress/scripts": "^32.1.0",
		"adm-zip": "^0.6.0"
	},
	"overrides": {
		"adm-zip": "^0.6.0",
		"@sentry/node": "^10.66.0",
		"markdownlint-cli": "^0.49.1",
		"serialize-javascript": "^7.0.7",
		"sockjs": {
			"uuid": "^11.1.1"
		},
		"webpack-dev-server": "^6.0.0"
	},
	"scripts": {
		"audit": "npm audit && composer audit",
		"lint": "npm run lint:js && npm run lint:md && npm run lint:pkg-json && npm run lint:php",
		"lint:js": "wp-scripts lint-js",
		"lint:md": "wp-scripts lint-md-docs",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"lint:php": "vendor/bin/phpcs",
		"format": "wp-scripts format",
		"test": "npm run test:unit && npm run test:integration && npm run test:e2e",
		"test:unit": "composer test",
		"test:integration": "wp-env run tests-cli --env-cwd='wp-content/plugins/mozcheck-plugin/' vendor/bin/phpunit --configuration phpunit.xml.dist",
		"test:e2e": "wp-scripts test-playwright",
		"test:package": "node scripts/validate-package.mjs dist/mozcheck.zip",
		"wp-env:start": "node scripts/wp-env-mailpit.mjs start",
		"wp-env:stop": "node scripts/wp-env-mailpit.mjs stop",
		"wp-env:destroy": "wp-env destroy",
		"wp-env:mail:send": "node scripts/wp-env-mailpit.mjs send",
		"build:zip": "wp-scripts plugin-zip && node scripts/move-package.mjs && npm run test:package",
		"validate:release": "node scripts/validate-release.mjs"
	}
}
