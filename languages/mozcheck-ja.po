msgctxt "Site Health tab label"
msgid "MozCheck"
msgstr "MozCheck"

msgid "MozCheck email notifications"
msgstr "MozCheckメール通知"

msgid "MozCheck emails a readable summary of Site Health issues, updates, and items that may no longer be needed."
msgstr "MozCheckはサイトヘルスの問題、更新、不要と思われる項目を読みやすくまとめてメールします。"

msgid "Notification status:"
msgstr "通知状態:"

msgid "Enabled"
msgstr "有効"

msgid "Disabled"
msgstr "無効"

msgid "Next scheduled check:"
msgstr "次回の定期診断:"

msgid "Open MozCheck settings"
msgstr "MozCheck設定を開く"

msgid "Mozcheck plugin."
msgstr "MozCheckプラグイン。"

msgid "You are not allowed to perform this action."
msgstr "この操作を実行する権限がありません。"

msgid "Monday"
msgstr "月曜日"
msgid "Tuesday"
msgstr "火曜日"
msgid "Wednesday"
msgstr "水曜日"
msgid "Thursday"
msgstr "木曜日"
msgid "Friday"
msgstr "金曜日"
msgid "Saturday"
msgstr "土曜日"
msgid "Sunday"
msgstr "日曜日"

msgid "Always send a report"
msgstr "常にレポートを送信"
msgid "When there is a critical or recommended item"
msgstr "重大または推奨項目がある場合"
msgid "When there is at least one critical item"
msgstr "重大な項目が1件以上ある場合"
msgid "When an update is available"
msgstr "更新がある場合"
msgid "When the result is worse than the previous scheduled check"
msgstr "前回の定期診断より悪化した場合"
msgid "Custom conditions"
msgstr "カスタム条件"

msgid "MozCheck Site Health email"
msgstr "MozCheck サイトヘルスメール"
msgid "Receive a readable reminder of WordPress Site Health results. WP-Cron runs when the site receives traffic, so delivery may be later than the selected time."
msgstr "WordPressサイトヘルスの結果を読みやすいメールで受け取れます。WP-Cronはサイトへのアクセス時に動作するため、指定時刻より配信が遅れる場合があります。"
msgid "The report email was sent."
msgstr "レポートメールを送信しました。"
msgid "The report could not be sent to every recipient."
msgstr "一部またはすべての宛先へレポートを送信できませんでした。"
msgid "Email notifications"
msgstr "メール通知"
msgid "Enable scheduled email notifications"
msgstr "定期メール通知を有効にする"
msgid "Recipients"
msgstr "通知先"
msgid "Enter one address per line or separate addresses with commas. Each recipient receives a separate email."
msgstr "1行に1件、またはカンマ区切りで入力してください。各宛先へ個別にメールを送信します。"
msgid "Schedule"
msgstr "スケジュール"
msgid "Weekly"
msgstr "週1回"
msgid "Monthly"
msgstr "月1回"
msgid "Weekday"
msgstr "曜日"
msgid "Day of month"
msgstr "日"
msgid "Times use the site timezone: %s. Monthly dates are limited to 1–28."
msgstr "時刻はサイトのタイムゾーン（%s）を使用します。月次の日付は1〜28日に限られます。"
msgid "Send when"
msgstr "通知条件"
msgid "Critical count is at least"
msgstr "重大な項目数が次以上"
msgid "Recommended count is at least"
msgstr "推奨項目数が次以上"
msgid "An update is available"
msgstr "更新がある"
msgid "Critical or recommended count increased"
msgstr "重大または推奨項目数が増えた"
msgid "Custom conditions are combined with OR: matching any selected condition sends the email."
msgstr "カスタム条件はORで結合され、選択した条件のいずれかに一致すると送信します。"
msgid "Report categories"
msgstr "通知対象カテゴリ"
msgid "Report status"
msgstr "通知状況"
msgid "Next scheduled check: %s"
msgstr "次回の定期診断: %s"
msgid "No report is scheduled."
msgstr "定期診断は予約されていません。"
msgid "Last check: %1$s — delivery status: %2$s"
msgstr "前回の診断: %1$s — 配信状態: %2$s"
msgid "Run diagnosis and send email now"
msgstr "今すぐ診断してメール送信"

msgid "[MozCheck] %s: Site Health is good"
msgstr "[MozCheck] %s: サイトヘルスは良好です"
msgid "[MozCheck] %1$s: %2$d critical, %3$d recommended"
msgstr "[MozCheck] %1$s: 重大 %2$d件、推奨 %3$d件"
msgid "Site Health report for %s"
msgstr "%s のサイトヘルスレポート"
msgid "Critical"
msgstr "重大"
msgid "Recommended"
msgstr "推奨"
msgid "Good"
msgstr "良好"
msgid "No problems were found in the selected categories."
msgstr "選択したカテゴリに問題はありませんでした。"
msgid "Items to review"
msgstr "確認が必要な項目"
msgid "Open Site Health"
msgstr "サイトヘルスを開く"
msgid "This email was sent by the MozCheck WordPress plugin."
msgstr "このメールはWordPressプラグイン MozCheck から送信されました。"

msgid "Updates"
msgstr "更新"
msgid "PHP and database"
msgstr "PHP / データベース"
msgid "REST API"
msgstr "REST API"
msgid "Loopback requests"
msgstr "ループバックリクエスト"
msgid "HTTPS and SSL"
msgstr "HTTPS / SSL"
msgid "Scheduled events"
msgstr "Cron / 定期イベント"
msgid "Unused plugins and themes"
msgstr "停止中プラグイン / 未使用テーマ"
msgid "Other Site Health tests"
msgstr "その他のサイトヘルステスト"
msgid "Enter at least one valid email address."
msgstr "有効なメールアドレスを1件以上入力してください。"
msgid "Select at least one report category."
msgstr "通知対象カテゴリを1件以上選択してください。"
msgid "Select at least one custom notification condition."
msgstr "カスタム通知条件を1件以上選択してください。"

msgid "A Site Health test is unavailable"
msgstr "サイトヘルステストを実行できません"
msgid "WordPress could not complete this Site Health test during the scheduled check."
msgstr "定期診断中にWordPressがこのサイトヘルステストを完了できませんでした。"
msgid "WordPress %s is available."
msgstr "WordPress %s を利用できます。"
msgid "A WordPress update is available"
msgstr "WordPressの更新があります"
msgid "%1$s can be updated to version %2$s."
msgstr "%1$s をバージョン %2$s に更新できます。"
msgid "A plugin update is available"
msgstr "プラグインの更新があります"
msgid "A theme update is available"
msgstr "テーマの更新があります"
msgid "%s is inactive. Remove it if it is no longer needed."
msgstr "%s は停止中です。不要であれば削除してください。"
msgid "An inactive plugin is installed"
msgstr "停止中のプラグインがあります"
msgid "%s is not active. Remove it if it is no longer needed."
msgstr "%s は使用されていません。不要であれば削除してください。"
msgid "An unused theme is installed"
msgstr "未使用のテーマがあります"
